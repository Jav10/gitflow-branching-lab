# Helper function for branch creation

create_branch() {
 local branch_name=$1
 local source_branch=$2
 
 if [ -z "$source_branch" ]; then
 source_branch="main"
 fi
 
 echo "Creating branch: $branch_name from $source_branch"
 git checkout $source_branch
 git pull origin $source_branch 2>/dev/null || echo "No remote tracking for $source_branch"
 git checkout -b $branch_name
 echo "Successfully created and switched to: $branch_name"
}

